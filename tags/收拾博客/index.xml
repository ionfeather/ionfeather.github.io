&lt;/div&gt;
&lt;div class="imgloop-lb-thumbs-wrap" style="display:none" aria-hidden="true"&gt;
&lt;div class="imgloop-lb-thumbs"&gt;&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;style&gt;
.imgloop-wrap {
position: relative;
overflow: hidden;
border-radius: 12px;
margin: 1.5em 0;
background: var(--card-background);
touch-action: pan-y;
}
.imgloop-track {
display: flex;
overflow-x: auto;
scroll-snap-type: x mandatory;
scroll-behavior: smooth;
-webkit-overflow-scrolling: touch;
scrollbar-width: none;
}
.imgloop-track::-webkit-scrollbar { display: none; }
.imgloop-slide {
flex: 0 0 100%;
scroll-snap-align: start;
display: flex;
align-items: center;
justify-content: center;
}
.imgloop-slide a {
display: flex;
align-items: center;
justify-content: center;
text-decoration: none;
border: none;
}
.imgloop-slide img {
max-width: 100%;
max-height: 520px;
width: auto;
height: auto;
object-fit: contain;
display: block;
border: none !important;
cursor: zoom-in;
}
.imgloop-dots {
position: absolute;
bottom: 10px;
left: 50%;
transform: translateX(-50%);
display: flex;
gap: 6px;
z-index: 2;
opacity: 1;
transition: opacity 0.4s ease;
}
.imgloop-dots.fade-out {
opacity: 0;
pointer-events: none;
}
.imgloop-dot {
width: 6px;
height: 6px;
border-radius: 50%;
background: rgba(255,255,255,0.5);
transition: background 0.2s, transform 0.2s;
cursor: pointer;
}
.imgloop-dot.active {
background: #fff;
transform: scale(1.3);
}
.gslide-image img {
max-width: 100vw !important;
max-height: 100vh !important;
object-fit: contain !important;
}
.imgloop-lb-toggle {
position: absolute;
right: 14px;
bottom: 14px;
z-index: 10003;
padding: 6px 12px;
border-radius: 20px;
border: none;
background: rgba(255,255,255,0.12);
color: rgba(255,255,255,0.85);
font-size: 13px;
line-height: 1;
cursor: pointer;
display: flex;
align-items: center;
justify-content: center;
opacity: 0.6;
transition: opacity 0.2s, background 0.2s;
pointer-events: auto;
}
.imgloop-lb-toggle:hover {
opacity: 1;
background: rgba(255,255,255,0.22);
}
.glightbox-container .imgloop-lb-thumbs-wrap {
position: absolute;
left: 0;
right: 0;
bottom: 0;
z-index: 10002;
display: none;
justify-content: center;
padding: 10px 20px 24px;
background: linear-gradient(to top, rgba(42,45,50,0.98) 0%, rgba(42,45,50,0.75) 50%, transparent);
pointer-events: auto;
}
.glightbox-container .imgloop-lb-thumbs-wrap.open {
display: flex;
}
.imgloop-lb-thumbs {
display: flex;
gap: 8px;
overflow-x: auto;
scrollbar-width: thin;
max-width: 100%;
}
.imgloop-lb-thumbs::-webkit-scrollbar { height: 6px; }
.imgloop-lb-thumbs::-webkit-scrollbar-thumb {
background: rgba(255,255,255,0.2);
border-radius: 3px;
}
.imgloop-lb-thumb {
flex: 0 0 auto;
width: 64px;
height: 64px;
border-radius: 4px;
overflow: hidden;
cursor: pointer;
opacity: 0.55;
transition: opacity 0.2s, transform 0.2s, border-color 0.2s;
border: 2px solid transparent;
background: rgba(0,0,0,0.2);
}
.imgloop-lb-thumb:hover { opacity: 0.9; }
.imgloop-lb-thumb.active {
opacity: 1;
border-color: var(--accent-color, #6b8e9e);
transform: translateY(-2px);
}
.imgloop-lb-thumb img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
}
@media (max-width: 640px) {
.imgloop-lb-thumb { width: 52px; height: 52px; }
}
&lt;/style&gt;
&lt;script&gt;
(function () {
var wrap = document.getElementById('imgloop-17');
if (!wrap) return;
var track = wrap.querySelector('.imgloop-track');
var slides = wrap.querySelectorAll('.imgloop-slide');
var dots = wrap.querySelectorAll('.imgloop-dot');
var total = slides.length;
var current = 0;
var dotsWrap = wrap.querySelector('.imgloop-dots');
var dotsTimer = null;
function wakeDots() {
dotsWrap.classList.remove('fade-out');
window.clearTimeout(dotsTimer);
dotsTimer = window.setTimeout(function () {
dotsWrap.classList.add('fade-out');
}, 2500);
}
function goTo(index) {
current = (index + total) % total;
track.scrollTo({ left: slides[current].offsetLeft, behavior: 'smooth' });
dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
wakeDots();
}
dots.forEach(function (d, i) { d.addEventListener('click', function () { goTo(i); }); });
var ticking = false;
track.addEventListener('scroll', function () {
wakeDots();
if (ticking) return;
ticking = true;
requestAnimationFrame(function () {
var idx = Math.round(track.scrollLeft / track.clientWidth);
if (idx !== current) {
current = idx;
dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
}
ticking = false;
});
});
wakeDots();
window.addEventListener('load', function () {
if (typeof GLightbox === 'undefined') {
console.warn('[imgloop] GLightbox not loaded');
return;
}
var sel = '.glightbox-imgloop-17';
var anchors = wrap.querySelectorAll(sel);
if (!anchors.length) return;
var lightbox = GLightbox({
selector: sel,
touchNavigation: true,
loop: true,
openEffect: 'zoom',
closeEffect: 'fade',
slideEffect: 'slide',
closeButton: true,
keyboardNavigation: true,
draggable: true,
closeOnOutsideClick: true,
zoomable: false
});
var thumbsWrap = wrap.querySelector('.imgloop-lb-thumbs-wrap');
var thumbs = thumbsWrap.querySelector('.imgloop-lb-thumbs');
anchors.forEach(function (a, i) {
var miniImg = a.querySelector('img');
var src = miniImg ? miniImg.src : a.href;
var alt = a.getAttribute('data-desc') || '';
var thumb = document.createElement('div');
thumb.className = 'imgloop-lb-thumb' + (i === 0 ? ' active' : '');
thumb.innerHTML = '&lt;img src="' + src + '" alt="' + alt + '" loading="lazy"&gt;';
thumb.addEventListener('click', function (e) {
e.stopPropagation();
lightbox.goToSlide(i);
});
thumbs.appendChild(thumb);
});
function syncThumbs(index) {
var t = thumbs.querySelectorAll('.imgloop-lb-thumb');
t.forEach(function (el, i) { el.classList.toggle('active', i === index); });
if (t[index]) t[index].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
}
var toggle = document.createElement('button');
toggle.className = 'imgloop-lb-toggle';
toggle.setAttribute('aria-label', '切换缩略图');
toggle.innerHTML = '&amp;#8942;&amp;#8942; 缩略图';
toggle.addEventListener('click', function (e) {
e.stopPropagation();
thumbsWrap.classList.toggle('open');
});
function showControls() {
var gb = document.querySelector('.glightbox-container');
if (gb) {
gb.appendChild(toggle);
gb.appendChild(thumbsWrap);
}
thumbsWrap.classList.remove('open');
syncThumbs(lightbox.getActiveSlideIndex() || 0);
}
function hideControls() {
thumbsWrap.classList.remove('open');
wrap.appendChild(thumbsWrap);
if (toggle.parentNode) toggle.parentNode.removeChild(toggle);
}
lightbox.on('open', function () {
showControls();
});
lightbox.on('slide_changed', function (ref) {
var idx = ref.current ? ref.current.index : (lightbox.getActiveSlideIndex() || 0);
syncThumbs(idx);
});
lightbox.on('close', function () {
hideControls();
});
});
})();
&lt;/script&gt;
