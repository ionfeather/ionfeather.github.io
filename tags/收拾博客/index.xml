color: #333;
border-radius: 15px;
position: relative;
width: fit-content;
}
.chat.--other::before {
content: "";
position: absolute;
left: -18px;
bottom: 5px;
transform: translateY(-50%);
border-width: 15px 20px 0 0;
border-style: solid;
border-color: transparent #ffecec transparent transparent;
}
.chat__meta {
font-weight: bold;
font-size: 0.67em;
color: #707070;
margin-bottom: 5px;
}
.chat__text {
font-size: 0.9em;
margin-left: 10px;
word-break: break-all;
}
