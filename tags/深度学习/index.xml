&lt;/h2&gt;&lt;p&gt;&lt;img src="https://ionfeather.github.io/2025/d2l-01/assets/image-20250108163545542.png"
width="574"
height="438"
srcset="https://ionfeather.github.io/2025/d2l-01/assets/image-20250108163545542_hu_6e6403cd23a33a0d.png 480w, https://ionfeather.github.io/2025/d2l-01/assets/image-20250108163545542_hu_51a8eb86df355109.png 1024w"
